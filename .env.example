# Pocket Option Login Credentials
POCKET_OPTION_EMAIL=your_email@example.com
POCKET_OPTION_PASSWORD=your_password

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Trading Configuration
TRADE_MODE=demo  # demo or live
MIN_CONFIDENCE=80  # Minimum % of indicators that must agree (80 = 2 out of 3)
EXPIRY_TIME=60  # 1 minute in seconds

# Assets to Trade (comma-separated)
TRADING_ASSETS=AUDCAD,EURUSD,GBPUSD,USDCAD,GOLD,BITCOIN

# Chart Settings
CHART_INTERVAL=1  # 1 minute candles
LOOKBACK_PERIODS=100  # Number of candles to analyze